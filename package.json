{
  "name": "incremental-game",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Competitive multiplayer incremental game",
  "scripts": {
    "dev": "pnpm --filter @game/shared build && concurrently -n shared,server,client -c yellow,blue,green \"pnpm --filter @game/shared dev\" \"pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev:shared": "pnpm --filter @game/shared dev",
    "build": "corepack enable && pnpm install && pnpm --filter @game/shared build && pnpm --filter client build && pnpm --filter server build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r exec vitest run --coverage",
    "typecheck": "pnpm --filter @game/shared build && tsc --noEmit -p shared/tsconfig.json && tsc --noEmit -p server/tsconfig.json && tsc --noEmit -p client/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "lint:css": "tsx scripts/lint-css.ts",
    "lint:exports": "knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deps:check": "pnpm outdated -r",
    "deps:update": "pnpm update -r",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@game/shared": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "knip": "~6.15.0",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "contributors": [
    "yonisimian",
    "Talnazar"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.1",
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npx knip --include exports,types",
    "pre-push": "pnpm typecheck && pnpm format:check && pnpm lint && pnpm lint:css"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc,yml,yaml,md,css,html}": "prettier --write",
    "*.ts": "eslint --fix",
    "*.md": "markdownlint-cli2 --fix"
  }
}
